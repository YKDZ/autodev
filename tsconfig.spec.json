{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": ["node", "vitest/globals"],
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    },
  },
  "include": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
