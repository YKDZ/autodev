# Auto-Dev environment template
# Fill these values before running in Docker / real integration tests.

# Required: GitHub App credentials
GITHUB_APP_ID=3532408
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
# Optional alternative to *_PATH (multiline PEM as env text)
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=127819771
GITHUB_REPOSITORY=YKDZ/autodev

# Required by orchestrator runtime
AUTO_DEV_WORKSPACE_ROOT=/opt/dev/autodev/autodev-data
AUTO_DEV_ALLOWED_USERS=YKDZ

# Agent provider secrets (if using Claude Code)
ANTHROPIC_API_KEY=sk-527f57034ceb4c84bf500d3137e9c4e7
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional runtime tuning
AUTO_DEV_DEFAULT_AGENT=full-pipeline
AUTO_DEV_POLL_INTERVAL_SEC=30
AUTO_DEV_MAX_DECISION_PER_RUN=20
AUTO_DEV_MAX_IMPL_CYCLES=5
AUTO_DEV_MAX_CONCURRENT_RUNS=3

# Decision service
AUTO_DEV_DECISION_HOST=
AUTO_DEV_DECISION_PORT=3000
AUTO_DEV_DECISION_TOKEN=autodev-test-token-2026
